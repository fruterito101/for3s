# For3s OS — environment configuration template.
# The installer (curl | sh) generates the real .env for you via a wizard.
# This file documents every variable. NEVER commit your real .env.

# ── Required ────────────────────────────────────────────────────────────────
# Your Claude (Anthropic) API key. Subscription token (sk-ant-oat01-...) or
# standard API key (sk-ant-api03-...).
ANTHROPIC_TOKEN=

# Your Telegram bot token (create a bot with @BotFather and paste its token).
TELEGRAM_BOT_TOKEN=

# Password for the bundled PostgreSQL container (the installer sets a random one).
POSTGRES_PASSWORD=

# ── Optional ────────────────────────────────────────────────────────────────
# A friendly name for your For3s instance (shown in the UI).
FOR3S_AGENT_NAME=For3s

# GitHub Personal Access Token — OPTIONAL integration (read/write repos).
# Leave empty to disable the GitHub features.
GITHUB_PAT=

# Which Claude model the agent uses.
FOR3S_MODEL=claude-sonnet-4-6

# ── Advanced (usually leave as default) ──────────────────────────────────────
# DATABASE_URL and VALKEY_HOST are set automatically by docker-compose to point
# at the bundled containers. Only override if you run your own Postgres/Valkey.
# DATABASE_URL=postgresql://for3s:<password>@postgres:5432/for3s
# VALKEY_HOST=valkey
# VALKEY_PORT=6379

# Nightly forgetting (Microglia): set to true to enable real deletion (default
# is dry-run). Recoverable soft-delete; never touches the audit chain.
# FOR3S_MICROGLIA_CONFIRMAR=false
